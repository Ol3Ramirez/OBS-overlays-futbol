# Copia este archivo como .env y rellena los valores.
# El archivo .env es gitignoreado — nunca se sube al repo.
#
# Uso:
#   Mac/Linux:  cp .env.example .env && nano .env
#   Windows:    copy .env.example .env && notepad .env

# Password del WebSocket de OBS Studio (puerto 4455)
# Encuéntralo en OBS -> Herramientas -> Servidor WebSocket -> Mostrar info de conexion
OBS_WS_PASSWORD=REPLACE_ME
